{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "place": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "badges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string"
          },
          "end": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "start",
          "end",
          "title"
        ]
      }
    },
    "lnglat": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ]
    },
    "organizer": {
      "type": "string"
    },
    "year": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "place",
    "url",
    "badges",
    "lnglat",
    "organizer",
    "year"
  ]
}